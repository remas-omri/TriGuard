<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/css/style.css" />
  <title>Alerts</title>
</head>

<body>

  <!-- Navbar موحّد -->
  <header class="topbar">
    <div style="display:flex; gap:10px; align-items:center;">
      <span class="badge">Smart Security</span>
      <span style="font-weight:700;">لوحة الإدارة</span>
    </div>

    <nav class="nav">
      <a href="/dashboard">Dashboard</a>
      <a href="/users">Users</a>
      <a href="/logs">Logs</a>
      <a href="/alerts">Alerts</a>
    </nav>

    <form method="POST" action="/logout" style="margin:0;">
      <button class="btn-outline" type="submit">تسجيل خروج</button>
    </form>
  </header>

  <main class="container">
    <div class="card">
      <h1>التنبيهات</h1>
      <p class="sub">تنبيهات تجريبية (Mock) — لاحقًا تصير تلقائيًا من قاعدة البيانات عند الفشل/الاشتباه.</p>
    </div>

    <div class="card" style="margin-top:14px;">
      <table>
        <tr>
          <th>ID</th>
          <th>Type</th>
          <th>Status</th>
          <th>Related Log</th>
          <th>Time</th>
        </tr>

        <tr>
          <td>501</td>
          <td><span class="pill pill-bad">unauthorized_attempt</span></td>
          <td><span class="pill">pending</span></td>
          <td>102</td>
          <td>2026-02-11 23:05</td>
        </tr>

        <tr>
          <td>502</td>
          <td><span class="pill pill-warn">suspicious_activity</span></td>
          <td><span class="pill pill-ok">sent</span></td>
          <td>103</td>
          <td>2026-02-11 23:12</td>
        </tr>
      </table>

      <div style="margin-top:12px;">
        <span class="pill pill-ok">أخضر فاتح</span>
        <span class="pill pill-warn">سماوي</span>
        <span class="pill pill-bad">بنفسجي</span>
      </div>
    </div>

  </main>

</body>
</html>
