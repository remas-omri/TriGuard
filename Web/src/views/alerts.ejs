<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/css/style.css" />
  <title>Alerts</title>
</head>

<body>
  <header class="topbar">
    <div>مرحبًا <b><%= user.full_name %></b> — (<%= user.role %>)</div>

    <nav class="nav">
      <a href="/dashboard">Dashboard</a>
      <a href="/users">Users</a>
      <a href="/logs">Logs</a>
      <a class="active" href="/alerts">Alerts</a>
    </nav>

    <form method="POST" action="/logout" style="margin:0;">
      <button class="btn-outline" type="submit">تسجيل خروج</button>
    </form>
  </header>

  <main class="container">
    <div class="card">
      <h1>التنبيهات</h1>
      <p class="sub">هذه التنبيهات من قاعدة البيانات (PostgreSQL)</p>

      <% if (error) { %>
        <div class="alert"><%= error %></div>
      <% } %>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Type</th>
              <th>Status</th>
              <th>Related Log</th>
              <th>المستخدم</th>
              <th>الدور</th>
              <th>Final</th>
              <th>وقت المحاولة</th>
              <th>وقت التنبيه</th>
            </tr>
          </thead>

          <tbody>
            <% (alerts || []).forEach(a => { %>
              <tr>
                <td><%= a.alert_id %></td>

                <td>
                  <% if (a.alert_type === 'unauthorized_attempt') { %>
                    <span class="pill pill-bad"><%= a.alert_type %></span>
                  <% } else if (a.alert_type === 'suspicious_activity') { %>
                    <span class="pill pill-warn"><%= a.alert_type %></span>
                  <% } else { %>
                    <span class="pill"><%= a.alert_type %></span>
                  <% } %>
                </td>

                <td>
                  <% if (a.status === 'sent') { %>
                    <span class="pill pill-ok">sent</span>
                  <% } else { %>
                    <span class="pill"><%= a.status %></span>
                  <% } %>
                </td>

                <td><%= a.log_id ?? '-' %></td>
                <td><%= a.full_name ?? 'Unknown' %></td>
                <td><%= a.role ?? '-' %></td>
                <td><%= a.final_result ?? '-' %></td>

                <td><%= a.attempt_time ? new Date(a.attempt_time).toLocaleString() : '-' %></td>
                <td><%= a.created_at ? new Date(a.created_at).toLocaleString() : '-' %></td>
              </tr>
            <% }) %>

            <% if (!alerts || alerts.length === 0) { %>
              <tr>
                <td colspan="9" style="text-align:center; padding:16px;">
                  لا يوجد تنبيهات حالياً
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</body>
</html>