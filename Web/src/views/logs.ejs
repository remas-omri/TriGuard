<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/css/style.css" />
  <title>Logs</title>
</head>

<body>

  <!-- Navbar موحّد -->
  <header class="topbar">
    <div style="display:flex; gap:10px; align-items:center;">
      <span class="badge">Smart Security</span>
      <span style="font-weight:700;">لوحة الإدارة</span>
    </div>

    <nav class="nav">
      <a href="/dashboard">Dashboard</a>
      <a href="/users">Users</a>
      <a href="/logs">Logs</a>
      <a href="/alerts">Alerts</a>
    </nav>

    <form method="POST" action="/logout" style="margin:0;">
      <button class="btn-outline" type="submit">تسجيل خروج</button>
    </form>
  </header>

  <main class="container">
    <div class="card">
      <h1>سجلات الدخول</h1>
      <p class="sub">هذه بيانات تجريبية (Mock) — لاحقًا تصير من قاعدة البيانات مباشرة.</p>
    </div>

    <div class="card" style="margin-top:14px;">
      <table>
        <tr>
          <th>ID</th>
          <th>User</th>
          <th>Face</th>
          <th>Voice</th>
          <th>ECG</th>
          <th>Final</th>
          <th>Time</th>
        </tr>

        <tr>
          <td>101</td>
          <td>Admin</td>
          <td><span class="pill pill-ok">pass</span></td>
          <td><span class="pill pill-warn">pass</span></td>
          <td><span class="pill pill-ok">pass</span></td>
          <td><span class="pill pill-ok">passed</span></td>
          <td>2026-02-11 23:00</td>
        </tr>

        <tr>
          <td>102</td>
          <td>Unknown</td>
          <td><span class="pill pill-ok">pass</span></td>
          <td><span class="pill pill-bad">fail</span></td>
          <td><span class="pill pill-ok">pass</span></td>
          <td><span class="pill pill-bad">failed</span></td>
          <td>2026-02-11 23:05</td>
        </tr>

        <tr>
          <td>103</td>
          <td>Security Officer</td>
          <td><span class="pill pill-bad">fail</span></td>
          <td><span class="pill pill-warn">pass</span></td>
          <td><span class="pill pill-ok">pass</span></td>
          <td><span class="pill pill-bad">failed</span></td>
          <td>2026-02-11 23:12</td>
        </tr>
      </table>
    </div>
  </main>

</body>
</html>
