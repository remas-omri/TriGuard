<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/css/style.css" />
  <title>Logs</title>
</head>
<body>
  <header class="topbar">
    <div>مرحبًا <b><%= user.full_name %></b> — (<%= user.role %>)</div>

    <nav class="nav">
      <a href="/dashboard">Dashboard</a>
      <a href="/users">Users</a>
      <a class="active" href="/logs">Logs</a>
      <a href="/alerts">Alerts</a>
    </nav>

    <form method="POST" action="/logout">
      <button class="btn-outline" type="submit">تسجيل خروج</button>
    </form>
  </header>

  <main class="container">
    <div class="card">
      <h1>سجلات الدخول</h1>
      <p class="sub">هذه السجلات من قاعدة البيانات (PostgreSQL)</p>

      <% if (error) { %>
        <div class="alert"><%= error %></div>
      <% } %>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>المستخدم</th>
              <th>الدور</th>
              <th>Face</th>
              <th>Voice</th>
              <th>ECG</th>
              <th>Final</th>
              <th>الوقت</th>
            </tr>
          </thead>

          <tbody>
            <% (logs || []).forEach(l => { %>
              <tr>
                <td><%= l.log_id %></td>
                <td><%= l.full_name %></td>
                <td><%= l.role %></td>
                <td><%= l.face_result %></td>
                <td><%= l.voice_result %></td>
                <td><%= l.ecg_result %></td>
                <td><%= l.final_result %></td>
                <td><%= l.attempt_time ? new Date(l.attempt_time).toLocaleString() : '-' %></td>
              </tr>
            <% }) %>

            <% if (!logs || logs.length === 0) { %>
              <tr>
                <td colspan="8" style="text-align:center; padding:16px;">
                  لا يوجد سجلات حالياً
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script src="/js/script.js"></script>
</body>
</html>