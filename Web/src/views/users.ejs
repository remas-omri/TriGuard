<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/css/style.css" />
  <title>Users</title>
</head>
<body>
  <header class="topbar">
    <div>مرحبًا <b><%= user.full_name %></b> — (<%= user.role %>)</div>

    <nav class="nav">
      <a href="/dashboard">Dashboard</a>
      <a class="active" href="/users">Users</a>
      <a href="/logs">Logs</a>
      <a href="/alerts">Alerts</a>
    </nav>

    <form method="POST" action="/logout">
      <button class="btn-outline" type="submit">تسجيل خروج</button>
    </form>
  </header>

  <main class="container">
    <div class="card">
      <h1>Users</h1>
      <p class="sub">قائمة المستخدمين من قاعدة البيانات (PostgreSQL)</p>

      <% if (error) { %>
        <div class="alert"><%= error %></div>
      <% } %>

      <form class="grid" method="POST" action="/users">
        <input name="full_name" placeholder="الاسم الكامل" required />
        <input name="email" type="email" placeholder="البريد الإلكتروني" required />
        <input name="password" type="password" placeholder="كلمة المرور" required />
        <select name="role">
          <option value="user">user</option>
          <option value="security">security</option>
          <option value="admin">admin</option>
        </select>
        <button class="btn" type="submit">إضافة</button>
      </form>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>الاسم</th>
              <th>الإيميل</th>
              <th>الدور</th>
              <th>تاريخ الإنشاء</th>
              <th>حذف</th>
            </tr>
          </thead>
          <tbody>
            <% (users || []).forEach(u => { %>
              <tr>
                <td><%= u.user_id %></td>
                <td><%= u.full_name %></td>
                <td><%= u.email %></td>
                <td><%= u.role %></td>
                <td><%= new Date(u.created_at).toLocaleString() %></td>
                <td>
                  <form method="POST" action="/users/<%= u.user_id %>/delete"
                        onsubmit="return confirm('متأكدة من الحذف؟')">
                    <button class="btn-outline" type="submit">حذف</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script src="/js/script.js"></script>
</body>
</html>
