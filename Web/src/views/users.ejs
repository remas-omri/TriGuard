<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/css/style.css" />
  <title>Users</title>
</head>

<body>

  <!-- Navbar موحّد -->
  <header class="topbar">
    <div style="display:flex; gap:10px; align-items:center;">
      <span class="badge">Smart Security</span>
      <span style="font-weight:700;">لوحة الإدارة</span>
    </div>

    <nav class="nav">
      <a href="/dashboard">Dashboard</a>
      <a href="/users">Users</a>
      <a href="/logs">Logs</a>
      <a href="/alerts">Alerts</a>
    </nav>

    <form method="POST" action="/logout" style="margin:0;">
      <button class="btn-outline" type="submit">تسجيل خروج</button>
    </form>
  </header>

  <main class="container">
    <div class="card">
      <h1>إدارة المستخدمين</h1>
      <p class="sub">حالياً هذه واجهة جاهزة — وربط قاعدة البيانات بيكون في خطوة لاحقة.</p>

      <!-- نموذج إضافة مستخدم (واجهة فقط اليوم) -->
      <div style="margin-top:14px;">
        <h2 style="margin:0 0 8px 0;">إضافة مستخدم</h2>

        <div style="display:grid; gap:10px; grid-template-columns: repeat(4, 1fr);">
          <input placeholder="الاسم الكامل" />
          <input placeholder="Email" />
          <input placeholder="Password" />
          <select>
            <option>user</option>
            <option>security</option>
            <option>admin</option>
          </select>
        </div>

        <button class="btn" style="width:auto; margin-top:10px;">إضافة (واجهة فقط)</button>
      </div>
    </div>

    <div class="card" style="margin-top:14px;">
      <h2 style="margin:0 0 10px 0;">قائمة المستخدمين (Mock)</h2>

      <table>
        <tr>
          <th>ID</th>
          <th>الاسم</th>
          <th>Email</th>
          <th>Role</th>
          <th>Action</th>
        </tr>

        <tr>
          <td>1</td>
          <td>Admin</td>
          <td>admin@demo.com</td>
          <td><span class="pill">admin</span></td>
          <td><button class="btn-outline" style="width:auto;">حذف</button></td>
        </tr>

        <tr>
          <td>2</td>
          <td>Security Officer</td>
          <td>security@demo.com</td>
          <td><span class="pill">security</span></td>
          <td><button class="btn-outline" style="width:auto;">حذف</button></td>
        </tr>

        <tr>
          <td>3</td>
          <td>User Test</td>
          <td>user@demo.com</td>
          <td><span class="pill">user</span></td>
          <td><button class="btn-outline" style="width:auto;">حذف</button></td>
        </tr>
      </table>
    </div>

  </main>

</body>
</html>
