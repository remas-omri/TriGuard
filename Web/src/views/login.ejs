<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="/css/style.css" />
  <title>Login</title>
</head>

<body>
  <main class="container" style="min-height:100vh; display:grid; place-items:center;">
    <div class="card" style="max-width:420px; width:100%;">
      <div style="display:flex; justify-content:space-between; align-items:center; gap:10px;">
        <div style="display:flex; gap:10px; align-items:center;">
          <span class="badge">Smart Security</span>
          <span style="font-weight:700;">لوحة الإدارة</span>
        </div>
        <span class="pill pill-ok">Secure</span>
      </div>

      <h1 style="margin-top:14px;">تسجيل الدخول</h1>
      <p class="sub">ادخلي بياناتك للوصول للوحة التحكم</p>

      <% if (error) { %>
        <div class="alert"><%= error %></div>
      <% } %>

      <form method="POST" action="/login">
        <label>الإيميل</label>
        <input name="email" type="email" placeholder="admin@demo.com" required />

        <label>كلمة المرور</label>
        <input name="password" type="password" placeholder="1234" required />

        <button class="btn" type="submit">دخول</button>

        <div style="margin-top:12px; display:flex; gap:8px; flex-wrap:wrap;">
          <span class="pill pill-warn">سماوي</span>
          <span class="pill pill-bad">بنفسجي</span>
          <span class="pill pill-ok">أخضر فاتح</span>
        </div>

        <p class="sub" style="margin-top:12px;">
          بيانات تجريبية: <b>admin@demo.com</b> / <b>1234</b>
        </p>
      </form>
    </div>
  </main>
</body>
</html>
